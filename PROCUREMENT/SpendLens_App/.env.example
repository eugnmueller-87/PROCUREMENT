# .env.example — documents every env var; holds NO real values.
# Copy to .env (git-ignored) and fill in. NEVER commit .env.
# In code, read these via os.getenv("NAME") — never hardcode the value.

# ─── LLM / AI provider ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ─── Railway deployment ───────────────────────────────────
PORT=8000
HADES_URL=https://your-hades-instance.up.railway.app

# ─── Redis / Upstash (rate limiting) ──────────────────────
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ─── App config ───────────────────────────────────────────
LOG_LEVEL=INFO
ENV=development
